type EventRecord = {
  id: number;
  slug: string;
  title: string;
  description: string | null;
  date: string | null;
  time: string | null;
  location: string | null;
  lat: number | null;
  lng: number | null;
  imageUrl: string | null;
  type: string;
  createdAt: string;
  updatedAt: string;
  published: number;
};

export const load: PageServerLoad = async ({ params, platform }) => {
  const db = platform?.env?.DB;
  if (!db) {
