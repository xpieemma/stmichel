describe('Bug 5 — package.json has full dev + migrate workflow', () => {
  const pkg = JSON.parse(read('package.json'));

  it('has `dev` for fast UI iteration (vite dev)', () => {
    expect(pkg.scripts.dev).toBe('vite dev');
