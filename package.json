{
	"name": "learning",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:cf": "pnpm build && pnpm wrangler pages dev .svelte-kit/cloudflare",
		"build": "vite build",
		"build:full": "wrangler types --check && vite build",
		"postbuild": "node scripts/copy-wasm.js",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"dev:wrangler": "pnpm build && wrangler pages dev .svelte-kit/cloudflare --d1=DB --kv=KV",
		"setup": "pnpm db:push && echo 'Ready! Run: pnpm dev'",
		"dev:full": "pnpm db:push && pnpm dev",
		"db:migrate:local": "wrangler d1 execute DB --local --file=migrations/001_init.sql",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright test",
		"gen": "wrangler types",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"verify": "curl -sf http://localhost:4173/healthz || echo 'FAIL'",
		"demo:clear": "wrangler d1 execute DB --local --command \"DELETE FROM events WHERE slug LIKE 'demo-%' AND title LIKE 'DEMO:%'; DELETE FROM matches WHERE slug LIKE 'demo-%' AND title LIKE 'DEMO:%'; DELETE FROM albums WHERE slug LIKE 'demo-%' AND title LIKE 'DEMO:%';\""
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.1.2",
		"@cloudflare/workers-types": "^4.20260502.1",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.6",
		"@storybook/addon-docs": "^10.3.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.6",
		"@storybook/sveltekit": "^10.3.6",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/canvas-confetti": "^1.9.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.6.0",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"better-auth": "~1.6.9",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.6",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.3.6",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.87.0"
	},
	"dependencies": {
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.0",
		"@sqlite.org/sqlite-wasm": "3.53.0-build1",
		"better-call": "1.3.5",
		"better-sqlite3": "^12.9.0",
		"canvas-confetti": "^1.9.4",
		"leaflet": "^1.9.4",
		"workbox-window": "^7.4.0"
	}
}
